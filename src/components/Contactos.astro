<!-- ─── SCRIPT ──────────────────────────────────────────────────────────── -->
<!--
  is:inline hace que Astro NO procese este script como módulo ES,
  por lo que document, window y el canvas están disponibles directamente.
  Si usas View Transitions, el evento 'astro:page-load' reemplaza a DOMContentLoaded.
-->
<script is:inline>
(function () {
  const canvas = document.getElementById('bg-canvas');
  const ctx    = canvas.getContext('2d');

  const YELLOW = '#f5a623';
  const BLUE1  = '#1b3f78';

  let W, H, particles;
  const NUM_PARTICLES = 90;

  const rand = (a, b) => a + Math.random() * (b - a);

  function resize() {
    W = canvas.width  = canvas.offsetWidth;
    H = canvas.height = canvas.offsetHeight;
    buildParticles();
  }

  function buildParticles() {
    particles = Array.from({ length: NUM_PARTICLES }, () => ({
      x:      rand(0, W),
      y:      rand(0, H),
      vx:     rand(-0.25, 0.25),
      vy:     rand(-0.18, 0.18),
      r:      rand(1.2, 3.2),
      alpha:  rand(0.25, 0.85),
      yellow: Math.random() < 0.12,
      phase:  rand(0, Math.PI * 2),
      speed:  rand(0.3, 0.8),
    }));
  }

  function drawHexGrid(t) {
    const size = 46;
    const cols = Math.ceil(W / (size * 1.73)) + 2;
    const rows = Math.ceil(H / (size * 1.5))  + 2;
    for (let row = -1; row < rows; row++) {
      for (let col = -1; col < cols; col++) {
        const xOff  = (row % 2) * size * 0.865;
        const cx    = col * size * 1.73 + xOff;
        const cy    = row * size * 1.5;
        const pulse = (Math.sin(t * 0.0006 + cx * 0.007 + cy * 0.005) + 1) / 2;
        ctx.beginPath();
        for (let i = 0; i < 6; i++) {
          const angle = (Math.PI / 3) * i - Math.PI / 6;
          const px = cx + size * 0.9 * Math.cos(angle);
          const py = cy + size * 0.9 * Math.sin(angle);
          i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
        }
        ctx.closePath();
        ctx.strokeStyle = BLUE1;
        ctx.lineWidth   = 0.8;
        ctx.globalAlpha = 0.025 + pulse * 0.045;
        ctx.stroke();
        ctx.globalAlpha = 1;
      }
    }
  }

  function drawLines() {
    const MAX_DIST = 130;
    for (let i = 0; i < particles.length; i++) {
      for (let j = i + 1; j < particles.length; j++) {
        const a = particles[i], b = particles[j];
        const dx = a.x - b.x, dy = a.y - b.y;
        const dist = Math.sqrt(dx*dx + dy*dy);
        if (dist > MAX_DIST) continue;
        ctx.beginPath();
        ctx.moveTo(a.x, a.y);
        ctx.lineTo(b.x, b.y);
        ctx.strokeStyle = (a.yellow || b.yellow) ? YELLOW : BLUE1;
        ctx.lineWidth   = 0.7;
        ctx.globalAlpha = (1 - dist / MAX_DIST) * 0.12;
        ctx.stroke();
        ctx.globalAlpha = 1;
      }
    }
  }

  function drawRings(t) {
    const cx = W * 0.5, cy = H * 0.5;
    const maxR = Math.hypot(cx, cy);
    [0, maxR * 0.55].forEach(offset => {
      const r        = ((t * 0.028 + offset) % maxR);
      const progress = r / maxR;
      const a        = Math.max(0, 0.18 * (1 - progress) * (1 - progress));
      ctx.beginPath();
      ctx.arc(cx, cy, r, 0, Math.PI * 2);
      ctx.strokeStyle = YELLOW;
      ctx.lineWidth   = 1.2;
      ctx.globalAlpha = a;
      ctx.stroke();
      ctx.globalAlpha = 1;
    });
  }

  function drawAurora(t) {
    const blobs = [
      { x: W * 0.2,  y: H * 0.25, rx: W * 0.38, ry: H * 0.28, color: 'rgba(27,63,120,0.22)' },
      { x: W * 0.78, y: H * 0.7,  rx: W * 0.32, ry: H * 0.24, color: 'rgba(245,166,35,0.055)' },
      { x: W * 0.55, y: H * 0.45, rx: W * 0.25, ry: H * 0.18, color: 'rgba(20,50,100,0.18)' },
    ];
    blobs.forEach((b, i) => {
      const dx   = Math.sin(t * 0.0004 + i * 1.4) * W * 0.04;
      const dy   = Math.cos(t * 0.0003 + i * 2.1) * H * 0.03;
      const grad = ctx.createRadialGradient(b.x + dx, b.y + dy, 0, b.x + dx, b.y + dy, Math.max(b.rx, b.ry));
      grad.addColorStop(0, b.color);
      grad.addColorStop(1, 'transparent');
      ctx.save();
      ctx.scale(1, b.ry / b.rx);
      ctx.beginPath();
      ctx.ellipse(b.x + dx, (b.y + dy) * (b.rx / b.ry), b.rx, b.rx, 0, 0, Math.PI * 2);
      ctx.fillStyle   = grad;
      ctx.globalAlpha = 0.8;
      ctx.fill();
      ctx.restore();
      ctx.globalAlpha = 1;
    });
  }

  function draw(t) {
    ctx.clearRect(0, 0, W, H);
    const bg = ctx.createLinearGradient(0, 0, W, H);
    bg.addColorStop(0,   '#09162a');
    bg.addColorStop(0.5, '#0e1e38');
    bg.addColorStop(1,   '#091528');
    ctx.fillStyle = bg;
    ctx.fillRect(0, 0, W, H);

    drawAurora(t);
    drawHexGrid(t);
    drawLines();

    particles.forEach(p => {
      p.x += p.vx; p.y += p.vy;
      if (p.x < 0) p.x = W; if (p.x > W) p.x = 0;
      if (p.y < 0) p.y = H; if (p.y > H) p.y = 0;
      const pulse = (Math.sin(t * 0.001 * p.speed + p.phase) + 1) / 2;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r + pulse * 1.5, 0, Math.PI * 2);
      ctx.fillStyle   = p.yellow ? YELLOW : '#3a6fc4';
      ctx.globalAlpha = p.alpha * (0.5 + pulse * 0.5);
      ctx.fill();
      ctx.globalAlpha = 1;
    });

    drawRings(t);
    requestAnimationFrame(draw);
  }

  window.addEventListener('resize', resize);
  resize();
  requestAnimationFrame(draw);
})();
</script>