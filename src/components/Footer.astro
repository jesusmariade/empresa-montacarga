<div class="Footer">
    <div class="copyright">
    <h4>® 2026 empresa que no sabemos el nombre</h4>
    </div>
    <div class=links>
    <a href="/Terminos-y-Condiciones">Terminos y Condiciones</a>
    <a href="/Aviso-de-privacidad">Aviso de Privacidad</a>
    </div>
</div>

<style>
.Footer{
    background: linear-gradient(90deg, #1B263B, #223A5E);
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    color: white;
    text-align: center;
}
.copyright{
    padding-top: 30px;
}
.copyright h4{
    font-family: 'DM Sans', 'Century Gothic', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-muted);
    justify-content: center;
}
.links{
    padding-bottom: 40px;
    padding-top: 20px;

}
.links a{
    font-family: 'DM Sans', 'Century Gothic', sans-serif;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
    position: relative;
    padding: 4px 12px;
    letter-spacing: 0.3px;
}
.links a::after {
    content: '';
    position: absolute;
    width: 0%;
    height: 1.5px;
    left: 50%;
    transform: translateX(-50%);
    bottom: -4px;
    background: var(--yellow);
    border-radius: 2px;
    transition: width 0.25s ease;
}
.links a:hover{
    color: var(--white);
}
.links a:hover::after {
    width: 100%;
}
</style>