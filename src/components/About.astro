<!-- ══ STYLES ════════════════════════════════════════════════════════════ -->
<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=Epilogue:ital,wght@0,300;0,400;0,500;1,300;1,700&display=swap');

  /* ── tokens ── */
  :root {
    --navy:    #0e1e38;
    --navy2:   #162840;
    --navy3:   #1d3356;
    --yellow:  #f5a623;
    --yellow2: #ffc14d;
    --white:   #ffffff;
    --cream:   #f5f3ee;
    --muted:   #7d8fa3;
    --dark:    #060f1e;
    --ease:    cubic-bezier(.22,.8,.36,1);
  }

  /* ── shared utilities ── */
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Epilogue', sans-serif;
    font-size: 0.67rem;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    padding: 0.3rem 0.85rem;
    border-radius: 100px;
    margin-bottom: 1.1rem;
    background: var(--yellow);
    color: var(--navy);
  }
  .chip--yellow {
    background: rgba(245,166,35,0.15);
    color: var(--yellow);
    border: 1px solid rgba(245,166,35,0.3);
  }
  .accent-text { color: var(--yellow); }

  .slash-bar {
    width: 48px;
    height: 4px;
    background: var(--yellow);
    margin-bottom: 1.4rem;
    clip-path: polygon(0 0, 100% 0, 88% 100%, 0 100%);
    border-radius: 2px;
  }
  .slash-bar--dark { background: var(--navy); }

  /* ── scroll reveal ── */
  .reveal, .reveal-left, .reveal-right {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.75s var(--ease), transform 0.75s var(--ease);
  }
  .reveal-left  { transform: translateX(-50px); }
  .reveal-right { transform: translateX(50px); }
  .reveal--delay1 { transition-delay: 0.12s; }
  .reveal--delay2 { transition-delay: 0.22s; }
  .reveal--delay3 { transition-delay: 0.34s; }

  .is-visible {
    opacity: 1 !important;
    transform: none !important;
  }

  /* ══ HERO ══════════════════════════════════════════════════════════════ */
  .hero {
    position: relative;
    height: 56vh;
    min-height: 420px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero__parallax {
    position: absolute;
    inset: -15% 0;
    background-size: cover;
    background-position: center;
    z-index: 0;
    will-change: transform;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(120deg,
        rgba(6,15,30,0.92) 0%,
        rgba(6,15,30,0.65) 55%,
        rgba(6,15,30,0.3)  100%);
    z-index: 1;
  }

  /* SVG grain texture overlay */
  .hero__grain {
    position: absolute;
    inset: 0;
    z-index: 2;
    opacity: 0.04;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 200px;
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    z-index: 3;
    padding: 0 clamp(2rem, 8vw, 9rem);
  }

  .hero__meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: 'Epilogue', sans-serif;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    margin-bottom: 1.4rem;
  }
  .hero__line {
    flex: 0 0 32px;
    height: 1px;
    background: rgba(255,255,255,0.25);
  }

  .hero__title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 800;
    color: var(--white);
    line-height: 1.0;
    letter-spacing: -2px;
    margin-bottom: 1rem;
  }
  .hero__title em {
    font-style: normal;
    color: var(--yellow);
    position: relative;
  }
  /* underline squiggle */
  .hero__title em::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0; right: 0;
    height: 4px;
    background: var(--yellow);
    clip-path: polygon(0 0, 100% 0, 96% 100%, 4% 100%);
    opacity: 0.5;
  }

  .hero__sub {
    font-family: 'Epilogue', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.38);
  }

  /* rotating badge */
  .hero__corner-badge {
    position: absolute;
    bottom: 3.5rem;
    right: clamp(2rem, 6vw, 5rem);
    z-index: 3;
    width: 80px; height: 80px;
    display: grid;
    place-items: center;
  }
  .hero__corner-ring {
    position: absolute;
    inset: 0;
    color: rgba(245,166,35,0.5);
    animation: spinSlow 12s linear infinite;
  }
  .hero__corner-text {
    font-family: 'Epilogue', sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    color: rgba(255,255,255,0.5);
    text-align: center;
    letter-spacing: 1px;
    line-height: 1.5;
  }

  /* wave divider */
  .hero__wave {
    position: absolute;
    bottom: -1px; left: 0; right: 0;
    z-index: 4;
    line-height: 0;
  }
  .hero__wave svg { width: 100%; height: 50px; }

  /* ══ QUIÉNES SOMOS ══════════════════════════════════════════════════════ */
  .qs {
    background: var(--navy);
    padding: clamp(5rem, 10vw, 9rem) clamp(2rem, 8vw, 9rem);
  }
  .qs__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* visual side */
  .qs__visual { position: relative; }

  .qs__img-outer {
    position: relative;
    padding-left: 2rem;
  }
  .qs__img-track {
    position: absolute;
    left: 0; top: 10%; bottom: 10%;
    width: 2px;
    background: linear-gradient(to bottom, transparent, var(--yellow), transparent);
    opacity: 0.5;
  }
  .qs__img-wrap {
    position: relative;
    overflow: hidden;
    border-radius: 14px;
  }
  .qs__img {
    width: 100%;
    height: 460px;
    object-fit: cover;
    display: block;
    transition: transform 0.6s var(--ease), filter 0.4s;
    filter: brightness(0.88) contrast(1.05) saturate(0.9);
  }
  .qs__img-wrap:hover .qs__img {
    transform: scale(1.04);
    filter: brightness(0.95) contrast(1.05) saturate(1);
  }
  /* shine sweep on hover */
  .qs__img-shine {
    position: absolute;
    inset: 0;
    background: linear-gradient(115deg, transparent 30%, rgba(255,255,255,0.12) 50%, transparent 70%);
    transform: translateX(-100%);
    transition: transform 0.7s ease;
    pointer-events: none;
  }
  .qs__img-wrap:hover .qs__img-shine { transform: translateX(100%); }

  /* floating stat card */
  .qs__float-card {
    position: absolute;
    bottom: -1.8rem;
    right: -1.8rem;
    background: var(--yellow);
    color: var(--navy);
    border-radius: 14px;
    padding: 1.2rem 1.6rem;
    box-shadow: 0 12px 40px rgba(0,0,0,0.4);
    text-align: center;
    z-index: 2;
  }
  .qs__float-num {
    display: block;
    font-family: 'Syne', sans-serif;
    font-size: 2.2rem;
    font-weight: 800;
    line-height: 1;
  }
  .qs__float-num sup { font-size: 1rem; vertical-align: super; }
  .qs__float-label {
    font-family: 'Epilogue', sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    opacity: 0.7;
    line-height: 1.3;
  }

  /* dots accent */
  .qs__dots {
    position: absolute;
    bottom: -2rem;
    left: -1.5rem;
    width: 120px; height: 120px;
    color: rgba(245,166,35,0.2);
    z-index: 0;
  }

  /* text side */
  .qs__title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.9rem, 3.2vw, 2.8rem);
    font-weight: 800;
    color: var(--white);
    line-height: 1.1;
    letter-spacing: -0.5px;
    margin-bottom: 0.8rem;
  }
  .qs__body {
    font-family: 'Epilogue', sans-serif;
    font-size: 1rem;
    font-weight: 300;
    color: var(--muted);
    line-height: 1.85;
    margin-bottom: 2.5rem;
  }

  /* stats */
  .qs__stats {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .qs__stat { text-align: left; }
  .qs__stat-num {
    display: block;
    font-family: 'Syne', sans-serif;
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--yellow);
    line-height: 1;
  }
  .qs__stat-suffix {
    font-family: 'Syne', sans-serif;
    font-size: 1.4rem;
    color: var(--yellow);
    vertical-align: super;
    margin-left: 1px;
  }
  .qs__stat-label {
    font-family: 'Epilogue', sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: var(--muted);
    margin-top: 0.2rem;
    display: block;
  }
  .qs__stat-div {
    width: 1px;
    height: 48px;
    background: rgba(255,255,255,0.1);
    flex-shrink: 0;
  }

  /* ══ HISTORIA ════════════════════════════════════════════════════════════ */
  .hist {
    background: var(--cream);
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 600px;
  }

  .hist__img-wrap {
    position: relative;
    overflow: hidden;
  }
  .hist__img {
    width: 100%;
    height: 100%;
    min-height: 500px;
    object-fit: cover;
    display: block;
    filter: saturate(0.7) brightness(0.85);
    transition: filter 0.5s;
  }
  .hist__img-wrap:hover .hist__img {
    filter: saturate(1) brightness(0.9);
  }
  .hist__img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent 60%, var(--cream) 100%);
    pointer-events: none;
  }
  .hist__img-label {
    position: absolute;
    bottom: 1.5rem; left: 1.5rem;
    font-family: 'Epilogue', sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    background: rgba(0,0,0,0.35);
    backdrop-filter: blur(4px);
    padding: 0.3rem 0.8rem;
    border-radius: 4px;
  }

  /* overlapping card */
  .hist__card {
    padding: clamp(3rem, 6vw, 6rem) clamp(2rem, 5vw, 5rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 2;
  }
  .hist__title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.9rem, 3vw, 2.8rem);
    font-weight: 800;
    color: var(--navy);
    line-height: 1.1;
    letter-spacing: -0.5px;
    margin-bottom: 0.8rem;
  }
  .hist__body {
    font-family: 'Epilogue', sans-serif;
    font-size: 0.97rem;
    font-weight: 300;
    color: #5a6a7e;
    line-height: 1.85;
    margin-bottom: 2.2rem;
  }

  /* vertical timeline */
  .vtl { position: relative; padding-left: 1.5rem; }
  .vtl__track {
    position: absolute;
    left: 5px; top: 8px; bottom: 8px;
    width: 1px;
    background: linear-gradient(to bottom, var(--yellow), rgba(245,166,35,0.1));
  }
  .vtl__item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 0.55rem 0;
    position: relative;
    transition: transform 0.2s;
  }
  .vtl__item:hover { transform: translateX(4px); }
  .vtl__dot {
    width: 11px; height: 11px;
    border-radius: 50%;
    background: var(--cream);
    border: 2px solid rgba(245,166,35,0.4);
    flex-shrink: 0;
    margin-top: 3px;
